RewriteEngine On

# If the request is for a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise redirect everything to index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]



# User visits: yoursite.com/games/list
#       ↓
# Root .htaccess → sends to public/
#       ↓
# public/.htaccess → sends to index.php?url=games/list
#       ↓
# public/index.php → your Router reads "games/list"
#       ↓
# Router → calls GamesController